{
  "permissions": {
    "allow": ["Read", "Write", "Edit", "MultiEdit", "Bash(git status:*)", "Bash(git log:*)", "Bash(git diff:*)", "Bash(ls:*)", "Bash(cat:*)", "Bash(echo:*)"],
    "deny": ["Bash(rm -rf:*)", "Bash(del:*)", "Write(**/.env)", "Write(**/.credentials*)", "Write(**/*secret*)", "Write(**/*key*)"]
  },
  "env": {
    "ANTHROPIC_BASE_URL": "http://127.0.0.1:4000",
    "PROJECT_NAME": "AI-atom"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write(**/SKILL.md)|Write(**/skill*.md)",
        "hooks": [
          {
            "type": "command",
            "command": "请对照以下原则检查刚创建的 SKILL.md：1.description 是否清楚说明何时使用？2. 正文是否只包含 AI 不具备的上下文？3. 有无不必要的冗余？4. 如果有 references 文件，正文是否保持了精简？发现问题直接指出并建议修改。"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "在结束前自检：1. 修复是否经过验证？2. 同类问题排查了吗？3. 上下游影响确认了吗？4. 有没有边界情况遗漏？"
          }
        ]
      }
    ]
  }
}
