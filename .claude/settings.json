{
  "permissions": {
    "allow": ["Read", "Write", "Edit", "MultiEdit", "Bash(git status:*)", "Bash(git log:*)", "Bash(git diff:*)", "Bash(ls:*)", "Bash(cat:*)", "Bash(echo:*)"],
    "deny": ["Bash(rm -rf:*)", "Bash(del:*)"]
  },
  "env": {
    "ANTHROPIC_BASE_URL": "https://api.minimaxi.com/anthropic",
    "ANTHROPIC_API_KEY": "sk-cp-X8eDfc1VJlwLedmR9bJANMxKVx-Qs1-Emp9W3kL5smj0HkfxHBwmpt7hstWKEAIb_Zz46vDiBm7Cta-blmS7hE6LbVNHrQpM2AhWM96cpyQaiDNFa31ApLI",
    "PROJECT_NAME": "AI-atom"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write(**/SKILL.md)|Write(**/skill*.md)",
        "hooks": [
          {
            "type": "command",
            "command": "Review the SKILL.md: 1. Is description clear? 2. No redundant info? 3. Keep concise if references exist? Provide feedback if issues found."
          }
